# Streamlit secrets template for ISMAP.
#
# Copy this file to `.streamlit/secrets.toml` and populate the values
# with environment-specific configuration if you prefer not to rely
# solely on `.env` files.

[aws]
region = "ap-southeast-2"
bucket_name = "ismap-data-lake"

[database]
host = "your-rds-endpoint.rds.amazonaws.com"
port = 5432
name = "ismap_warehouse"
user = "admin"
password = "your_password"

