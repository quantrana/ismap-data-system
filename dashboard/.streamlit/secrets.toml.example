# Streamlit secrets template for ISMAP.
#
# Copy this file to `dashboard/.streamlit/secrets.toml` and fill in values.
# Use quoted strings for passwords (required if the password contains `#` or spaces).

[aws]
region = "ap-southeast-2"
bucket_name = "ismap-data-lake"

[database]
host = "your-rds-endpoint.rds.amazonaws.com"
port = 5432
name = "ismap_warehouse"
user = "admin"
password = "your_password"

